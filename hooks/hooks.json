{
  "hooks": [
    {
      "type": "PostToolUse",
      "matcher": {
        "tool_name": "Bash"
      },
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$PLUGIN_DIR/hooks/check-gc-logging.sh\""
        }
      ]
    },
    {
      "type": "PreToolUse",
      "matcher": {
        "tool_name": "Write|Edit"
      },
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$PLUGIN_DIR/hooks/check-dockerfile-gc.sh\""
        }
      ]
    }
  ]
}
